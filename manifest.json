{
  "manifest_version": 3,
  "name": "CFx",
  "version": "1.0.0",
  "description": "CFx — The all-in-one Codeforces power extension. Dark mode, tag hider, problem timer, bookmarks & multi-platform contest tracker.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.codeforces.com/*",
    "*://*.codechef.com/*",
    "*://*.atcoder.jp/*",
    "*://*.leetcode.com/*"
  ],
  "action": {
    "default_title": "CFx — Codeforces Power Tools",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.codeforces.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "darkmode.css"],
      "matches": ["*://*.codeforces.com/*"]
    }
  ]
}
